# InsurAI Environment Configuration
# Copy this to .env and fill in real values

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=insurai-super-secret-key-min-32-chars-change-in-production

# ─── Database (auto-configured by docker-compose) ────────────────────────────
POSTGRES_USER=insurai
POSTGRES_PASSWORD=insurai123

# ─── AI API Keys ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# OR for Anthropic:
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email (for notify-service) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── Optional: File storage ───────────────────────────────────────────────────
# For production, use S3:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=insurai-documents
AWS_REGION=ap-south-1

# ─── Dev Defaults (already set in docker-compose) ────────────────────────────
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# REDIS_URL=redis://redis:6379
